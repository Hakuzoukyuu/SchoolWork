<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.OfficeNoticeMapper">
    
    <resultMap type="OfficeNotice" id="OfficeNoticeResult">
        <result property="noticeId"    column="notice_id"    />
        <result property="noticeTitle"    column="notice_title"    />
        <result property="noticeType"    column="notice_type"    />
        <result property="noticeContent"    column="notice_content"    />
        <result property="receiverDept"    column="receiver_dept"    />
        <result property="receiverUser"    column="receiver_user"    />
        <result property="fileUrl"    column="file_url"    />
        <result property="publisher"    column="publisher"    />
        <result property="publishTime"    column="publish_time"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectOfficeNoticeVo">
        select notice_id, notice_title, notice_type, notice_content, receiver_dept, receiver_user, file_url, publisher, publish_time, status, remark, create_time, update_time from office_notice
    </sql>

    <select id="selectOfficeNoticeList" parameterType="OfficeNotice" resultMap="OfficeNoticeResult">
        <include refid="selectOfficeNoticeVo"/>
        <where>  
            <if test="noticeTitle != null  and noticeTitle != ''"> and notice_title = #{noticeTitle}</if>
            <if test="noticeType != null  and noticeType != ''"> and notice_type = #{noticeType}</if>
            <if test="noticeContent != null  and noticeContent != ''"> and notice_content = #{noticeContent}</if>
            <if test="receiverDept != null  and receiverDept != ''"> and receiver_dept = #{receiverDept}</if>
            <if test="receiverUser != null  and receiverUser != ''"> and receiver_user = #{receiverUser}</if>
            <if test="fileUrl != null  and fileUrl != ''"> and file_url = #{fileUrl}</if>
            <if test="publisher != null  and publisher != ''"> and publisher = #{publisher}</if>
            <if test="publishTime != null "> and publish_time = #{publishTime}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectOfficeNoticeByNoticeId" parameterType="Long" resultMap="OfficeNoticeResult">
        <include refid="selectOfficeNoticeVo"/>
        where notice_id = #{noticeId}
    </select>

    <insert id="insertOfficeNotice" parameterType="OfficeNotice" useGeneratedKeys="true" keyProperty="noticeId">
        insert into office_notice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="noticeTitle != null and noticeTitle != ''">notice_title,</if>
            <if test="noticeType != null and noticeType != ''">notice_type,</if>
            <if test="noticeContent != null">notice_content,</if>
            <if test="receiverDept != null">receiver_dept,</if>
            <if test="receiverUser != null">receiver_user,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="publisher != null and publisher != ''">publisher,</if>
            <if test="publishTime != null">publish_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="noticeTitle != null and noticeTitle != ''">#{noticeTitle},</if>
            <if test="noticeType != null and noticeType != ''">#{noticeType},</if>
            <if test="noticeContent != null">#{noticeContent},</if>
            <if test="receiverDept != null">#{receiverDept},</if>
            <if test="receiverUser != null">#{receiverUser},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="publisher != null and publisher != ''">#{publisher},</if>
            <if test="publishTime != null">#{publishTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateOfficeNotice" parameterType="OfficeNotice">
        update office_notice
        <trim prefix="SET" suffixOverrides=",">
            <if test="noticeTitle != null and noticeTitle != ''">notice_title = #{noticeTitle},</if>
            <if test="noticeType != null and noticeType != ''">notice_type = #{noticeType},</if>
            <if test="noticeContent != null">notice_content = #{noticeContent},</if>
            <if test="receiverDept != null">receiver_dept = #{receiverDept},</if>
            <if test="receiverUser != null">receiver_user = #{receiverUser},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="publisher != null and publisher != ''">publisher = #{publisher},</if>
            <if test="publishTime != null">publish_time = #{publishTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where notice_id = #{noticeId}
    </update>

    <delete id="deleteOfficeNoticeByNoticeId" parameterType="Long">
        delete from office_notice where notice_id = #{noticeId}
    </delete>

    <delete id="deleteOfficeNoticeByNoticeIds" parameterType="String">
        delete from office_notice where notice_id in 
        <foreach item="noticeId" collection="array" open="(" separator="," close=")">
            #{noticeId}
        </foreach>
    </delete>

</mapper>