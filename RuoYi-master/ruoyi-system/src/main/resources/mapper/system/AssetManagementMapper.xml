<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AssetManagementMapper">
    
    <resultMap type="AssetManagement" id="AssetManagementResult">
        <result property="id"    column="id"    />
        <result property="assetType"    column="asset_type"    />
        <result property="assetName"    column="asset_name"    />
        <result property="assetSpec"    column="asset_spec"    />
        <result property="assetNum"    column="asset_num"    />
        <result property="useDepartment"    column="use_department"    />
        <result property="usePeople"    column="use_people"    />
        <result property="assetStatus"    column="asset_status"    />
        <result property="receiveTime"    column="receive_time"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAssetManagementVo">
        select id, asset_type, asset_name, asset_spec, asset_num, use_department, use_people, asset_status, receive_time, remark, create_time, update_time from asset_management
    </sql>

    <select id="selectAssetManagementList" parameterType="AssetManagement" resultMap="AssetManagementResult">
        <include refid="selectAssetManagementVo"/>
        <where>  
            <if test="assetType != null  and assetType != ''"> and asset_type = #{assetType}</if>
            <if test="assetName != null  and assetName != ''"> and asset_name like concat('%', #{assetName}, '%')</if>
            <if test="assetSpec != null  and assetSpec != ''"> and asset_spec = #{assetSpec}</if>
            <if test="assetNum != null "> and asset_num = #{assetNum}</if>
            <if test="useDepartment != null  and useDepartment != ''"> and use_department = #{useDepartment}</if>
            <if test="usePeople != null  and usePeople != ''"> and use_people = #{usePeople}</if>
            <if test="assetStatus != null  and assetStatus != ''"> and asset_status = #{assetStatus}</if>
            <if test="receiveTime != null "> and receive_time = #{receiveTime}</if>
        </where>
    </select>
    
    <select id="selectAssetManagementById" parameterType="Long" resultMap="AssetManagementResult">
        <include refid="selectAssetManagementVo"/>
        where id = #{id}
    </select>

    <insert id="insertAssetManagement" parameterType="AssetManagement" useGeneratedKeys="true" keyProperty="id">
        insert into asset_management
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="assetType != null and assetType != ''">asset_type,</if>
            <if test="assetName != null and assetName != ''">asset_name,</if>
            <if test="assetSpec != null">asset_spec,</if>
            <if test="assetNum != null">asset_num,</if>
            <if test="useDepartment != null and useDepartment != ''">use_department,</if>
            <if test="usePeople != null">use_people,</if>
            <if test="assetStatus != null and assetStatus != ''">asset_status,</if>
            <if test="receiveTime != null">receive_time,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="assetType != null and assetType != ''">#{assetType},</if>
            <if test="assetName != null and assetName != ''">#{assetName},</if>
            <if test="assetSpec != null">#{assetSpec},</if>
            <if test="assetNum != null">#{assetNum},</if>
            <if test="useDepartment != null and useDepartment != ''">#{useDepartment},</if>
            <if test="usePeople != null">#{usePeople},</if>
            <if test="assetStatus != null and assetStatus != ''">#{assetStatus},</if>
            <if test="receiveTime != null">#{receiveTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateAssetManagement" parameterType="AssetManagement">
        update asset_management
        <trim prefix="SET" suffixOverrides=",">
            <if test="assetType != null and assetType != ''">asset_type = #{assetType},</if>
            <if test="assetName != null and assetName != ''">asset_name = #{assetName},</if>
            <if test="assetSpec != null">asset_spec = #{assetSpec},</if>
            <if test="assetNum != null">asset_num = #{assetNum},</if>
            <if test="useDepartment != null and useDepartment != ''">use_department = #{useDepartment},</if>
            <if test="usePeople != null">use_people = #{usePeople},</if>
            <if test="assetStatus != null and assetStatus != ''">asset_status = #{assetStatus},</if>
            <if test="receiveTime != null">receive_time = #{receiveTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAssetManagementById" parameterType="Long">
        delete from asset_management where id = #{id}
    </delete>

    <delete id="deleteAssetManagementByIds" parameterType="String">
        delete from asset_management where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>