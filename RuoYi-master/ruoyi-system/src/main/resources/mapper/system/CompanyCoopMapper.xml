<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CompanyCoopMapper">
    
    <resultMap type="CompanyCoop" id="CompanyCoopResult">
        <result property="companyId"    column="company_id"    />
        <result property="companyName"    column="company_name"    />
        <result property="companyAddress"    column="company_address"    />
        <result property="contactPerson"    column="contact_person"    />
        <result property="contactPhone"    column="contact_phone"    />
        <result property="coopStatus"    column="coop_status"    />
        <result property="coopContent"    column="coop_content"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <resultMap id="CompanyCoopStudentInternshipResult" type="CompanyCoop" extends="CompanyCoopResult">
        <collection property="studentInternshipList" ofType="StudentInternship" column="company_id" select="selectStudentInternshipList" />
    </resultMap>

    <resultMap type="StudentInternship" id="StudentInternshipResult">
        <result property="internshipId"    column="internship_id"    />
        <result property="studentId"    column="student_id"    />
        <result property="studentName"    column="student_name"    />
        <result property="studentType"    column="student_type"    />
        <result property="major"    column="major"    />
        <result property="companyId"    column="company_id"    />
        <result property="internshipPost"    column="internship_post"    />
        <result property="internshipStart"    column="internship_start"    />
        <result property="internshipEnd"    column="internship_end"    />
        <result property="internshipStatus"    column="internship_status"    />
        <result property="reportStatus"    column="report_status"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectCompanyCoopVo">
        select company_id, company_name, company_address, contact_person, contact_phone, coop_status, coop_content, remark, create_time, update_time from company_coop
    </sql>

    <select id="selectCompanyCoopList" parameterType="CompanyCoop" resultMap="CompanyCoopResult">
        <include refid="selectCompanyCoopVo"/>
        <where>  
            <if test="companyName != null  and companyName != ''"> and company_name like concat('%', #{companyName}, '%')</if>
            <if test="companyAddress != null  and companyAddress != ''"> and company_address = #{companyAddress}</if>
            <if test="contactPerson != null  and contactPerson != ''"> and contact_person = #{contactPerson}</if>
            <if test="contactPhone != null  and contactPhone != ''"> and contact_phone = #{contactPhone}</if>
            <if test="coopStatus != null  and coopStatus != ''"> and coop_status = #{coopStatus}</if>
            <if test="coopContent != null  and coopContent != ''"> and coop_content = #{coopContent}</if>
        </where>
    </select>
    
    <select id="selectCompanyCoopByCompanyId" parameterType="String" resultMap="CompanyCoopStudentInternshipResult">
        select company_id, company_name, company_address, contact_person, contact_phone, coop_status, coop_content, remark, create_time, update_time
        from company_coop
        where company_id = #{companyId}
    </select>

    <select id="selectStudentInternshipList" resultMap="StudentInternshipResult">
        select internship_id, student_id, student_name, student_type, major, company_id, internship_post, internship_start, internship_end, internship_status, report_status, remark, create_time, update_time
        from student_internship
        where company_id = #{company_id}
    </select>

    <insert id="insertCompanyCoop" parameterType="CompanyCoop">
        insert into company_coop
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="companyId != null">company_id,</if>
            <if test="companyName != null and companyName != ''">company_name,</if>
            <if test="companyAddress != null">company_address,</if>
            <if test="contactPerson != null">contact_person,</if>
            <if test="contactPhone != null">contact_phone,</if>
            <if test="coopStatus != null">coop_status,</if>
            <if test="coopContent != null">coop_content,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="companyId != null">#{companyId},</if>
            <if test="companyName != null and companyName != ''">#{companyName},</if>
            <if test="companyAddress != null">#{companyAddress},</if>
            <if test="contactPerson != null">#{contactPerson},</if>
            <if test="contactPhone != null">#{contactPhone},</if>
            <if test="coopStatus != null">#{coopStatus},</if>
            <if test="coopContent != null">#{coopContent},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateCompanyCoop" parameterType="CompanyCoop">
        update company_coop
        <trim prefix="SET" suffixOverrides=",">
            <if test="companyName != null and companyName != ''">company_name = #{companyName},</if>
            <if test="companyAddress != null">company_address = #{companyAddress},</if>
            <if test="contactPerson != null">contact_person = #{contactPerson},</if>
            <if test="contactPhone != null">contact_phone = #{contactPhone},</if>
            <if test="coopStatus != null">coop_status = #{coopStatus},</if>
            <if test="coopContent != null">coop_content = #{coopContent},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where company_id = #{companyId}
    </update>

    <delete id="deleteCompanyCoopByCompanyId" parameterType="String">
        delete from company_coop where company_id = #{companyId}
    </delete>

    <delete id="deleteCompanyCoopByCompanyIds" parameterType="String">
        delete from company_coop where company_id in 
        <foreach item="companyId" collection="array" open="(" separator="," close=")">
            #{companyId}
        </foreach>
    </delete>
    
    <delete id="deleteStudentInternshipByCompanyIds" parameterType="String">
        delete from student_internship where company_id in 
        <foreach item="companyId" collection="array" open="(" separator="," close=")">
            #{companyId}
        </foreach>
    </delete>

    <delete id="deleteStudentInternshipByCompanyId" parameterType="String">
        delete from student_internship where company_id = #{companyId}
    </delete>

    <insert id="batchStudentInternship">
        insert into student_internship( internship_id, student_id, student_name, student_type, major, company_id, internship_post, internship_start, internship_end, internship_status, report_status, remark, create_time, update_time) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.internshipId}, #{item.studentId}, #{item.studentName}, #{item.studentType}, #{item.major}, #{item.companyId}, #{item.internshipPost}, #{item.internshipStart}, #{item.internshipEnd}, #{item.internshipStatus}, #{item.reportStatus}, #{item.remark}, #{item.createTime}, #{item.updateTime})
        </foreach>
    </insert>

</mapper>