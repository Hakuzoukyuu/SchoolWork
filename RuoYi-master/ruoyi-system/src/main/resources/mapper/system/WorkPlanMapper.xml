<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.WorkPlanMapper">
    
    <resultMap type="WorkPlan" id="WorkPlanResult">
        <result property="planId"    column="plan_id"    />
        <result property="deptName"    column="dept_name"    />
        <result property="planType"    column="plan_type"    />
        <result property="planPeriod"    column="plan_period"    />
        <result property="planContent"    column="plan_content"    />
        <result property="summaryContent"    column="summary_content"    />
        <result property="submitter"    column="submitter"    />
        <result property="submitTime"    column="submit_time"    />
        <result property="status"    column="status"    />
        <result property="auditRemark"    column="audit_remark"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectWorkPlanVo">
        select plan_id, dept_name, plan_type, plan_period, plan_content, summary_content, submitter, submit_time, status, audit_remark, remark, create_time, update_time from work_plan
    </sql>

    <select id="selectWorkPlanList" parameterType="WorkPlan" resultMap="WorkPlanResult">
        <include refid="selectWorkPlanVo"/>
        <where>  
            <if test="deptName != null  and deptName != ''"> and dept_name like concat('%', #{deptName}, '%')</if>
            <if test="planType != null  and planType != ''"> and plan_type = #{planType}</if>
            <if test="planPeriod != null  and planPeriod != ''"> and plan_period = #{planPeriod}</if>
            <if test="planContent != null  and planContent != ''"> and plan_content = #{planContent}</if>
            <if test="summaryContent != null  and summaryContent != ''"> and summary_content = #{summaryContent}</if>
            <if test="submitter != null  and submitter != ''"> and submitter = #{submitter}</if>
            <if test="submitTime != null "> and submit_time = #{submitTime}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="auditRemark != null  and auditRemark != ''"> and audit_remark = #{auditRemark}</if>
        </where>
    </select>
    
    <select id="selectWorkPlanByPlanId" parameterType="Long" resultMap="WorkPlanResult">
        <include refid="selectWorkPlanVo"/>
        where plan_id = #{planId}
    </select>

    <insert id="insertWorkPlan" parameterType="WorkPlan" useGeneratedKeys="true" keyProperty="planId">
        insert into work_plan
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">dept_name,</if>
            <if test="planType != null and planType != ''">plan_type,</if>
            <if test="planPeriod != null and planPeriod != ''">plan_period,</if>
            <if test="planContent != null">plan_content,</if>
            <if test="summaryContent != null">summary_content,</if>
            <if test="submitter != null and submitter != ''">submitter,</if>
            <if test="submitTime != null">submit_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="auditRemark != null">audit_remark,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">#{deptName},</if>
            <if test="planType != null and planType != ''">#{planType},</if>
            <if test="planPeriod != null and planPeriod != ''">#{planPeriod},</if>
            <if test="planContent != null">#{planContent},</if>
            <if test="summaryContent != null">#{summaryContent},</if>
            <if test="submitter != null and submitter != ''">#{submitter},</if>
            <if test="submitTime != null">#{submitTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="auditRemark != null">#{auditRemark},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateWorkPlan" parameterType="WorkPlan">
        update work_plan
        <trim prefix="SET" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">dept_name = #{deptName},</if>
            <if test="planType != null and planType != ''">plan_type = #{planType},</if>
            <if test="planPeriod != null and planPeriod != ''">plan_period = #{planPeriod},</if>
            <if test="planContent != null">plan_content = #{planContent},</if>
            <if test="summaryContent != null">summary_content = #{summaryContent},</if>
            <if test="submitter != null and submitter != ''">submitter = #{submitter},</if>
            <if test="submitTime != null">submit_time = #{submitTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="auditRemark != null">audit_remark = #{auditRemark},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where plan_id = #{planId}
    </update>

    <delete id="deleteWorkPlanByPlanId" parameterType="Long">
        delete from work_plan where plan_id = #{planId}
    </delete>

    <delete id="deleteWorkPlanByPlanIds" parameterType="String">
        delete from work_plan where plan_id in 
        <foreach item="planId" collection="array" open="(" separator="," close=")">
            #{planId}
        </foreach>
    </delete>

</mapper>