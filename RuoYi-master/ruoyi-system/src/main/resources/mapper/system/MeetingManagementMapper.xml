<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MeetingManagementMapper">
    
    <resultMap type="MeetingManagement" id="MeetingManagementResult">
        <result property="meetingId"    column="meeting_id"    />
        <result property="meetingTitle"    column="meeting_title"    />
        <result property="meetingRoom"    column="meeting_room"    />
        <result property="meetingDate"    column="meeting_date"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="organizer"    column="organizer"    />
        <result property="attendees"    column="attendees"    />
        <result property="meetingContent"    column="meeting_content"    />
        <result property="meetingMinutes"    column="meeting_minutes"    />
        <result property="fileUrl"    column="file_url"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMeetingManagementVo">
        select meeting_id, meeting_title, meeting_room, meeting_date, start_time, end_time, organizer, attendees, meeting_content, meeting_minutes, file_url, status, remark, create_time, update_time from meeting_management
    </sql>

    <select id="selectMeetingManagementList" parameterType="MeetingManagement" resultMap="MeetingManagementResult">
        <include refid="selectMeetingManagementVo"/>
        <where>  
            <if test="meetingTitle != null  and meetingTitle != ''"> and meeting_title = #{meetingTitle}</if>
            <if test="meetingRoom != null  and meetingRoom != ''"> and meeting_room = #{meetingRoom}</if>
            <if test="meetingDate != null "> and meeting_date = #{meetingDate}</if>
            <if test="startTime != null "> and start_time = #{startTime}</if>
            <if test="endTime != null "> and end_time = #{endTime}</if>
            <if test="organizer != null  and organizer != ''"> and organizer = #{organizer}</if>
            <if test="attendees != null  and attendees != ''"> and attendees = #{attendees}</if>
            <if test="meetingContent != null  and meetingContent != ''"> and meeting_content = #{meetingContent}</if>
            <if test="meetingMinutes != null  and meetingMinutes != ''"> and meeting_minutes = #{meetingMinutes}</if>
            <if test="fileUrl != null  and fileUrl != ''"> and file_url = #{fileUrl}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectMeetingManagementByMeetingId" parameterType="Long" resultMap="MeetingManagementResult">
        <include refid="selectMeetingManagementVo"/>
        where meeting_id = #{meetingId}
    </select>

    <insert id="insertMeetingManagement" parameterType="MeetingManagement" useGeneratedKeys="true" keyProperty="meetingId">
        insert into meeting_management
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="meetingTitle != null and meetingTitle != ''">meeting_title,</if>
            <if test="meetingRoom != null and meetingRoom != ''">meeting_room,</if>
            <if test="meetingDate != null">meeting_date,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="organizer != null and organizer != ''">organizer,</if>
            <if test="attendees != null">attendees,</if>
            <if test="meetingContent != null">meeting_content,</if>
            <if test="meetingMinutes != null">meeting_minutes,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="meetingTitle != null and meetingTitle != ''">#{meetingTitle},</if>
            <if test="meetingRoom != null and meetingRoom != ''">#{meetingRoom},</if>
            <if test="meetingDate != null">#{meetingDate},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="organizer != null and organizer != ''">#{organizer},</if>
            <if test="attendees != null">#{attendees},</if>
            <if test="meetingContent != null">#{meetingContent},</if>
            <if test="meetingMinutes != null">#{meetingMinutes},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateMeetingManagement" parameterType="MeetingManagement">
        update meeting_management
        <trim prefix="SET" suffixOverrides=",">
            <if test="meetingTitle != null and meetingTitle != ''">meeting_title = #{meetingTitle},</if>
            <if test="meetingRoom != null and meetingRoom != ''">meeting_room = #{meetingRoom},</if>
            <if test="meetingDate != null">meeting_date = #{meetingDate},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="organizer != null and organizer != ''">organizer = #{organizer},</if>
            <if test="attendees != null">attendees = #{attendees},</if>
            <if test="meetingContent != null">meeting_content = #{meetingContent},</if>
            <if test="meetingMinutes != null">meeting_minutes = #{meetingMinutes},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where meeting_id = #{meetingId}
    </update>

    <delete id="deleteMeetingManagementByMeetingId" parameterType="Long">
        delete from meeting_management where meeting_id = #{meetingId}
    </delete>

    <delete id="deleteMeetingManagementByMeetingIds" parameterType="String">
        delete from meeting_management where meeting_id in 
        <foreach item="meetingId" collection="array" open="(" separator="," close=")">
            #{meetingId}
        </foreach>
    </delete>

</mapper>